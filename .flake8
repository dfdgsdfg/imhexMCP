[flake8]
# Configuration for flake8 to work with black formatter
# See: https://black.readthedocs.io/en/stable/guides/using_black_with_other_tools.html

# Ignore known black/flake8 conflicts
ignore =
    E203,  # whitespace before ':' (black adds this in slices)
    E122,  # continuation line missing indentation (black formats differently)

# Match black's line length
max-line-length = 79

# Exclude common directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .hypothesis,
    .pytest_cache,

# Per-file ignores (if needed in future)
per-file-ignores =
    # Example: __init__.py:F401
