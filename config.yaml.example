# ImHex MCP Server Configuration
# Copy this file to config.yaml and customize as needed

# Server Connection Settings
connection:
  host: "localhost"
  port: 31337
  timeout: 30.0  # seconds
  max_retries: 3
  retry_delay: 1.0  # seconds

# Performance Settings
performance:
  enable_compression: true
  compression_threshold: 1024  # bytes
  max_workers: 4
  request_timeout: 60.0  # seconds

# Cache Settings
cache:
  enabled: true
  max_size: 1000  # number of entries
  ttl: 300  # seconds (5 minutes)
  enable_l2_cache: true
  l2_max_size: 10000

# Security Settings
security:
  enable_rate_limiting: true
  requests_per_second: 100
  max_payload_size: 10485760  # 10 MB
  enable_input_validation: true

# Monitoring Settings
monitoring:
  enable_metrics: true
  metrics_port: 8000
  enable_prometheus: false
  log_level: "INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Circuit Breaker Settings
circuit_breaker:
  enabled: true
  failure_threshold: 5
  timeout: 60.0  # seconds
  half_open_timeout: 30.0  # seconds

# Request Priority Settings
priority:
  enable_aging: true
  aging_interval: 1.0  # seconds
  max_queue_size: 1000

# Logging Settings
logging:
  format: "json"  # json or console
  file: null  # null for stdout, or path to log file
  level: "INFO"
  enable_colors: true
