diff --git a/plugins/builtin/source/content/providers/file_provider.cpp b/plugins/builtin/source/content/providers/file_provider.cpp
index 3c49087fb..0591c89ea 100644
--- a/plugins/builtin/source/content/providers/file_provider.cpp
+++ b/plugins/builtin/source/content/providers/file_provider.cpp
@@ -234,7 +234,14 @@ namespace hex::plugin::builtin {
     }
 
     prv::Provider::OpenResult FileProvider::open() {
-        const auto maxMemoryFileSize = ContentRegistry::Settings::read<u64>("hex.builtin.setting.general", "hex.builtin.setting.general.max_mem_file_size", 128_MiB);
+        // Try to read settings, but gracefully handle when settings system is not initialized
+        // (e.g., when called via network interface before ImHex fully starts)
+        size_t maxMemoryFileSize = 128_MiB; // Default value
+        try {
+            maxMemoryFileSize = ContentRegistry::Settings::read<u64>("hex.builtin.setting.general", "hex.builtin.setting.general.max_mem_file_size", 128_MiB);
+        } catch (const std::exception &e) {
+            hex::log::debug("FileProvider::open: Settings not available, using default max memory file size ({}): {}", maxMemoryFileSize, e.what());
+        }
 
         size_t fileSize = 0x00;
         {
@@ -351,26 +358,38 @@ namespace hex::plugin::builtin {
     }
 
     void FileProvider::loadSettings(const nlohmann::json &settings) {
-        Provider::loadSettings(settings);
+        // Gracefully handle when settings are not available or incomplete
+        // (e.g., when FileProvider is created programmatically via network interface)
+        try {
+            Provider::loadSettings(settings);
+
+            auto pathString = settings.at("path").get<std::string>();
+            std::fs::path path = std::u8string(pathString.begin(), pathString.end());
+
+            if (auto projectPath = ProjectFile::getPath(); !projectPath.empty()) {
+                std::fs::path fullPath;
+                try {
+                    fullPath = std::fs::weakly_canonical(projectPath.parent_path() / path);
+                } catch (const std::fs::filesystem_error &) {
+                    fullPath = projectPath.parent_path() / path;
+                }
 
-        auto pathString = settings.at("path").get<std::string>();
-        std::fs::path path = std::u8string(pathString.begin(), pathString.end());
+                if (!wolv::io::fs::exists(fullPath))
+                    fullPath = path;
 
-        if (auto projectPath = ProjectFile::getPath(); !projectPath.empty()) {
-            std::fs::path fullPath;
-            try {
-                fullPath = std::fs::weakly_canonical(projectPath.parent_path() / path);
-            } catch (const std::fs::filesystem_error &) {
-                fullPath = projectPath.parent_path() / path;
-            }
+                if (!wolv::io::fs::exists(fullPath)) {
+                    this->setErrorMessage(fmt::format("hex.builtin.provider.file.error.open"_lang, m_path.string(), formatSystemError(ENOENT)));
+                }
 
-            if (!wolv::io::fs::exists(fullPath))
-                fullPath = path;
+                path = std::move(fullPath);
+            }
 
-            path = std::move(fullPath);
+            this->setPath(path);
+        } catch (const std::exception &e) {
+            // If settings are not available or incomplete, silently ignore
+            // The path should have been set via setPath() before calling loadSettings()
+            hex::log::debug("FileProvider::loadSettings: Settings not complete, path should be set manually: {}", e.what());
         }
-
-        this->setPath(path);
     }
 
     nlohmann::json FileProvider::storeSettings(nlohmann::json settings) const {
--- a/plugins/mcp/source/plugin_mcp.cpp
+++ b/plugins/mcp/source/plugin_mcp.cpp
@@ -70,10 +70,11 @@
                     auto fileProvider = std::make_unique<hex::plugin::builtin::FileProvider>();
                     fileProvider->setPath(std::fs::path(request.path));
 
-                    if (!fileProvider->open(false)) {
+                    auto openResult = fileProvider->open(false);
+                    if (!openResult.isSuccess()) {
                         request.status = "error";
-                        request.error_message = "Failed to open file";
-                        hex::log::error("MCP: Failed to open file: {}", request.path);
+                        request.error_message = std::string(openResult.getErrorMessage());
+                        hex::log::error("MCP: Failed to open file '{}': {}", request.path, request.error_message);
                         continue;
                     }
 
