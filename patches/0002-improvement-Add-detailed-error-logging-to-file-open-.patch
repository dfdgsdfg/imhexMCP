From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Pavel Polikashin <polikashin@celestialtech.io>
Date: Tue, 11 Nov 2025 22:12:14 -0500
Subject: [PATCH 2/2] improvement: Add detailed error logging to file/open
 queue processor
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Capture actual error messages from OpenResult::getErrorMessage() instead of
generic 'Failed to open file' message. This provides better diagnostic information
for troubleshooting file opening issues.

Updated for upstream API change: open(bool) now returns OpenResult instead of bool.

---
diff --git a/cmake/build_helpers.cmake b/cmake/build_helpers.cmake
index 384fe96e0..76cd3a5cb 100644
--- a/cmake/build_helpers.cmake
+++ b/cmake/build_helpers.cmake
@@ -580,9 +580,11 @@ function(verifyCompiler)
         message(FATAL_ERROR "ImHex requires GCC 12.0.0 or newer. Please use the latest GCC version.")
     elseif (CMAKE_CXX_COMPILER_ID STREQUAL "Clang" AND CMAKE_CXX_COMPILER_VERSION VERSION_LESS "17.0.0")
         message(FATAL_ERROR "ImHex requires Clang 17.0.0 or newer. Please use the latest Clang version.")
+    elseif (CMAKE_CXX_COMPILER_ID STREQUAL "AppleClang" AND CMAKE_CXX_COMPILER_VERSION VERSION_LESS "15.0.0")
+        message(FATAL_ERROR "ImHex requires AppleClang 15.0.0 or newer. Please update Xcode.")
     elseif(CMAKE_CXX_COMPILER_ID STREQUAL "MSVC")
-        
-    elseif (NOT (CMAKE_CXX_COMPILER_ID STREQUAL "GNU" OR CMAKE_CXX_COMPILER_ID STREQUAL "Clang"))
+
+    elseif (NOT (CMAKE_CXX_COMPILER_ID STREQUAL "GNU" OR CMAKE_CXX_COMPILER_ID STREQUAL "Clang" OR CMAKE_CXX_COMPILER_ID STREQUAL "AppleClang"))
         message(FATAL_ERROR "ImHex can only be compiled with GCC or Clang. ${CMAKE_CXX_COMPILER_ID} is not supported.")
     endif()
 endfunction()
diff --git a/lib/libimhex/source/providers/provider.cpp b/lib/libimhex/source/providers/provider.cpp
index 4cd87c430..6b07c0e71 100644
--- a/lib/libimhex/source/providers/provider.cpp
+++ b/lib/libimhex/source/providers/provider.cpp
@@ -289,8 +289,16 @@ namespace hex::prv {
     }
 
     void Provider::loadSettings(const nlohmann::json &settings) {
-        m_baseAddress = settings["baseAddress"];
-        m_currPage    = settings["currPage"];
+        // Gracefully handle when settings are not available or incomplete
+        try {
+            m_baseAddress = settings["baseAddress"];
+            m_currPage    = settings["currPage"];
+        } catch (const std::exception &e) {
+            // If settings are missing, use default values
+            hex::log::debug("Provider::loadSettings: Using default values (baseAddress=0, currPage=0): {}", e.what());
+            m_baseAddress = 0;
+            m_currPage = 0;
+        }
     }
 
     std::pair<Region, bool> Provider::getRegionValidity(u64 address) const {
