From ad21dd3e1da56fef36eaf4f8e91ba713416fe4d7 Mon Sep 17 00:00:00 2001
From: Pavel Polikashin <polikashin@celestialtech.io>
Date: Tue, 11 Nov 2025 01:09:01 -0500
Subject: [PATCH 11/16] Add batch/search endpoint for v1.0.0 Phase 2
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Implements multi-pattern, multi-file search capability:
- Search multiple patterns across all open files or specified subset
- Supports hex, string/text pattern types
- 1MB chunk-based searching for memory efficiency
- Configurable max_matches_per_file limit (default 1000)
- Returns per-file, per-pattern results with match offsets
- Summary statistics (files_searched, total_matches, patterns_searched)
- Proper type safety (u32 for provider IDs)

Part of batch operations feature for automated binary analysis workflows.


---
 plugins/mcp/source/plugin_mcp.cpp | 132 +++++++++++++++++++++++++++++-
 1 file changed, 131 insertions(+), 1 deletion(-)

diff --git a/plugins/mcp/source/plugin_mcp.cpp b/plugins/mcp/source/plugin_mcp.cpp
index 72f6e3b83..a67baa0a4 100644
--- a/plugins/mcp/source/plugin_mcp.cpp
+++ b/plugins/mcp/source/plugin_mcp.cpp
@@ -25,6 +25,7 @@
 #include <iomanip>
 #include <fstream>
 #include <filesystem>
+#include <numeric>
 
 namespace hex::plugin::mcp {
 
@@ -1506,7 +1507,136 @@ namespace hex::plugin::mcp {
                 }
             });
 
-            log::info("MCP plugin (improved) loaded - registered {} network endpoints", 21);
+            // Batch Search: Search for patterns across multiple files
+            ContentRegistry::CommunicationInterface::registerNetworkEndpoint("batch/search", [](const nlohmann::json &data) -> nlohmann::json {
+                try {
+                    // Parse parameters
+                    auto patterns = data.at("patterns").get<std::vector<nlohmann::json>>();
+                    size_t max_matches_per_file = data.value("max_matches_per_file", 1000);
+
+                    // Get provider IDs to search (if not specified, search all)
+                    std::vector<u32> provider_ids;
+                    if (data.contains("provider_ids")) {
+                        auto ids = data["provider_ids"].get<std::vector<int>>();
+                        for (int id : ids) {
+                            provider_ids.push_back(static_cast<u32>(id));
+                        }
+                    } else {
+                        // Search all open providers
+                        auto providers = ImHexApi::Provider::getProviders();
+                        for (auto& prov : providers) {
+                            provider_ids.push_back(prov->getID());
+                        }
+                    }
+
+                    if (provider_ids.empty()) {
+                        throw std::runtime_error("No files open to search");
+                    }
+
+                    // Results structure
+                    std::vector<nlohmann::json> results;
+                    size_t total_matches = 0;
+
+                    // Search each provider
+                    for (u32 provider_id : provider_ids) {
+                        // Find provider by ID
+                        prv::Provider* provider = nullptr;
+                        auto providers = ImHexApi::Provider::getProviders();
+                        for (auto& prov : providers) {
+                            if (prov->getID() == provider_id) {
+                                provider = prov;
+                                break;
+                            }
+                        }
+
+                        if (!provider) {
+                            log::warn("MCP: Provider ID {} not found, skipping", provider_id);
+                            continue;
+                        }
+
+                        nlohmann::json provider_result;
+                        provider_result["provider_id"] = provider_id;
+                        provider_result["file"] = provider->getName();
+                        std::vector<nlohmann::json> pattern_results;
+
+                        // Search each pattern in this provider
+                        for (const auto& pattern_obj : patterns) {
+                            std::string pattern_value = pattern_obj.at("value").get<std::string>();
+                            std::string pattern_type = pattern_obj.at("type").get<std::string>();
+
+                            std::vector<u8> searchBytes;
+                            if (pattern_type == "hex") {
+                                searchBytes = hexStringToBytes(pattern_value);
+                            } else if (pattern_type == "string" || pattern_type == "text") {
+                                searchBytes.assign(pattern_value.begin(), pattern_value.end());
+                            } else {
+                                log::warn("MCP: Unsupported pattern type: {}", pattern_type);
+                                continue;
+                            }
+
+                            if (searchBytes.empty()) continue;
+
+                            // Search implementation (same as search/find)
+                            std::vector<u64> matches;
+                            const size_t chunkSize = 1024 * 1024; // 1 MB chunks
+                            std::vector<u8> buffer(chunkSize + searchBytes.size());
+                            u64 fileSize = provider->getActualSize();
+
+                            for (u64 offset = 0; offset < fileSize && matches.size() < max_matches_per_file; offset += chunkSize) {
+                                size_t readSize = std::min(chunkSize + searchBytes.size(), static_cast<size_t>(fileSize - offset));
+                                provider->read(offset, buffer.data(), readSize);
+
+                                // Search for pattern in this chunk
+                                for (size_t i = 0; i <= readSize - searchBytes.size() && matches.size() < max_matches_per_file; i++) {
+                                    bool found = true;
+                                    for (size_t j = 0; j < searchBytes.size(); j++) {
+                                        if (buffer[i + j] != searchBytes[j]) {
+                                            found = false;
+                                            break;
+                                        }
+                                    }
+                                    if (found) {
+                                        matches.push_back(offset + i);
+                                    }
+                                }
+                            }
+
+                            nlohmann::json pattern_result;
+                            pattern_result["pattern"] = pattern_value;
+                            pattern_result["type"] = pattern_type;
+                            pattern_result["match_count"] = matches.size();
+                            pattern_result["matches"] = matches;
+                            pattern_result["limited"] = (matches.size() >= max_matches_per_file);
+
+                            pattern_results.push_back(pattern_result);
+                            total_matches += matches.size();
+                        }
+
+                        provider_result["patterns"] = pattern_results;
+                        provider_result["total_matches"] = std::accumulate(
+                            pattern_results.begin(), pattern_results.end(), 0,
+                            [](int sum, const nlohmann::json& p) { return sum + p["match_count"].get<int>(); }
+                        );
+                        results.push_back(provider_result);
+                    }
+
+                    nlohmann::json result;
+                    result["results"] = results;
+                    result["summary"] = {
+                        {"files_searched", provider_ids.size()},
+                        {"total_matches", total_matches},
+                        {"patterns_searched", patterns.size()}
+                    };
+
+                    log::info("MCP: Batch search complete - {} files, {} total matches", provider_ids.size(), total_matches);
+
+                    return result;
+                } catch (const std::exception &e) {
+                    throw std::runtime_error(fmt::format("Batch search failed: {}", e.what()));
+                }
+            });
+
+            log::info("MCP plugin (improved) loaded - registered {} network endpoints", 22);
         }
 
     }
