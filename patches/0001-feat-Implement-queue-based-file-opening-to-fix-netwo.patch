+        // ===== FILE OPEN REQUEST QUEUE (Solution for network thread issue) =====
+        struct FileOpenRequest {
+            uint64_t id;
+            std::string path;
+            std::string status;  // "pending", "processing", "success", "error"
+            std::string error_message;
+            uint64_t file_size = 0;
+        };
+
+        static std::atomic<uint64_t> s_nextRequestId{1};
+        static std::mutex s_requestQueueMutex;
+        static std::map<uint64_t, FileOpenRequest> s_fileOpenRequests;
+
+        /**
+         * Process pending file open requests on main thread
+         * This runs periodically and is completely decoupled from network callbacks
+         */
+        void processFileOpenQueue() {
+            std::lock_guard<std::mutex> lock(s_requestQueueMutex);
+
+            // Find first pending request
+            for (auto& [id, request] : s_fileOpenRequests) {
+                if (request.status != "pending") continue;
+
+                // Mark as processing
+                request.status = "processing";
+
+                hex::log::info("MCP: Processing queued file open request {}: {}", id, request.path);
+
+                try {
+                    // Create and open file provider
+                    auto fileProvider = std::make_unique<hex::plugin::builtin::FileProvider>();
+                    fileProvider->setPath(std::fs::path(request.path));
+
+                    if (!fileProvider->open(false)) {
+                        request.status = "error";
+                        request.error_message = "Failed to open file";
+                        hex::log::error("MCP: Failed to open file: {}", request.path);
+                        continue;
+                    }
+
+                    request.file_size = fileProvider->getActualSize();
+
+                    // Add provider - THIS happens on main thread, NOT network thread
+                    hex::ImHexApi::Provider::add(std::move(fileProvider), true);
+
+                    request.status = "success";
+                    hex::log::info("MCP: Successfully opened file: {}", request.path);
+
+                } catch (const std::exception &e) {
+                    request.status = "error";
+                    request.error_message = e.what();
+                    hex::log::error("MCP: File open error: {}", e.what());
+                }
+
+                // Only process one request per call to avoid blocking
+                break;
+            }
+
+            // Clean up old completed requests (keep last 100)
+            if (s_fileOpenRequests.size() > 100) {
+                std::vector<uint64_t> completed_ids;
+                for (const auto& [id, req] : s_fileOpenRequests) {
+                    if (req.status == "success" || req.status == "error") {
+                        completed_ids.push_back(id);
+                    }
+                }
+
+                // Keep only the most recent 100 completed
+                if (completed_ids.size() > 100) {
+                    std::sort(completed_ids.begin(), completed_ids.end());
+                    for (size_t i = 0; i < completed_ids.size() - 100; i++) {
+                        s_fileOpenRequests.erase(completed_ids[i]);
+                    }
+                }
+            }
+        }
